rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Tutto l'accesso a Firestore passa dal backend (Cloud Functions, Admin SDK),
    // che bypassa queste regole. Nessun client deve leggere/scrivere direttamente.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
